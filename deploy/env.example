# ── Co-Computing: variables de entorno para docker-compose ────────────────────
#
# Copia este fichero como backend/.env y rellena los valores reales.
# NUNCA comitear el .env con secretos reales.
#
# ── Supabase ──────────────────────────────────────────────────────────────────

# URL del proyecto Supabase (panel: Settings -> API -> Project URL)
SUPABASE_URL=https://<project-ref>.supabase.co

# Clave service_role (panel: Settings -> API -> service_role key). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cadena de conexión directa PostgreSQL (puerto 6543 = transaction pooler de Supabase)
# Formato: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────

# Clave secreta mínimo 32 caracteres. Generar con: openssl rand -hex 32
JWT_SECRET_KEY=<cambia_esto_min_32_chars_aleatorios>

# Algoritmo de firma (no cambiar salvo justificación)
JWT_ALGORITHM=HS256

# Días de validez del token de sesión
JWT_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────

# URL exacta del frontend (sin trailing slash).
# En local con docker-compose: http://localhost:3000
# En producción: https://tudominio.com
FRONTEND_URL=http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────

# development → activa /docs, /redoc, log level INFO
# production  → desactiva /docs, /redoc, log level WARNING
ENVIRONMENT=development

# ── Frontend (build-time, leídas por Vite) ────────────────────────────────────

# URL base del backend. Se inyecta en el build del frontend como VITE_API_URL.
# En local: http://localhost:8000
# En producción: https://api.tudominio.com
VITE_API_URL=http://localhost:8000
