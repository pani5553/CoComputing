# Crea tu API key en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Modelo por defecto para todos los agentes (barato y bueno)
FACTORY_MODEL=claude-sonnet-4-6

# Modelo para roles de direccion/arquitectura (CEO, CTO, Architect).
# Por defecto = Sonnet (barato). Descomenta la linea de Opus si quieres mas
# calidad en vision/arquitectura a cambio de ~5x el coste de esos 3 roles.
FACTORY_MODEL_DIRECTOR=claude-sonnet-4-6
# FACTORY_MODEL_DIRECTOR=claude-opus-4-8

# Iteraciones maximas de tool-use por agente (acota el peor caso de coste)
FACTORY_MAX_ITERATIONS=25
